<Window x:Class="SteelCoatingTakeoff.App.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection settings"
        Height="620" Width="440"
        MinHeight="480" MinWidth="380"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="SAGE CONNECTION" Style="{StaticResource H2}"/>

                    <TextBlock Text="SQL Server" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Settings.SqlServer}"
                             ToolTip="Instance holding the estimates DB, e.g. WILLS-LAPTOP\SAGE_EST25."/>
                    <TextBlock Text="Estimating database" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Settings.Database}"/>
                    <TextBlock Text="Standard database (assemblies)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Settings.StandardDatabase}"/>
                    <TextBlock Text="Estimate name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Settings.EstimateName}"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ASSEMBLIES" Style="{StaticResource H2}"/>
                        <Button Grid.Column="1" Content="Load from Sage" Command="{Binding LoadAssembliesCommand}"
                                Padding="8,3" Margin="0,0,0,8"/>
                    </Grid>
                    <TextBlock Text="{Binding AssemblyLoadStatus}" Foreground="{StaticResource Muted}"
                               FontSize="10" Margin="0,0,0,4" TextWrapping="Wrap"/>

                    <TextBlock Text="Intumescent assembly (YES)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding AssemblyChoices}" DisplayMemberPath="Display"
                                  SelectedValuePath="Name" SelectedValue="{Binding IntumescentAssembly}"
                                  ToolTip="Pick a loaded assembly, or Browse the grouped list."/>
                        <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="8,3"
                                Click="BrowseIntumescent_Click"/>
                    </Grid>

                    <TextBlock Text="Standard steel assembly (NO)" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" ItemsSource="{Binding AssemblyChoices}" DisplayMemberPath="Display"
                                  SelectedValuePath="Name" SelectedValue="{Binding StandardAssembly}"
                                  ToolTip="Pick a loaded assembly, or Browse the grouped list."/>
                        <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="8,3"
                                Click="BrowseStandard_Click"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Intumescent labor item" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Settings.IntumescentLaborItemMatch}"
                                     ToolTip="Description substring of the item that carries labor on the intumescent assembly (default 'Insulation')."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Standard labor item" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Settings.StandardLaborItemMatch}"
                                     ToolTip="Description substring of the item that carries labor on the standard assembly. Blank = every item."/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="ADVANCED" Style="{StaticResource H2}" Margin="0,14,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Area variable (blank = quantity)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Settings.AreaVariableName}"
                                     ToolTip="Blank sends the area as the assembly's takeoff quantity (correct for an SF assembly with no calculation, e.g. 3000.310.01)."/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="LF variable (opt.)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Settings.LinearFeetVariableName}"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Dry run (simulate — write nothing to Sage)"
                              IsChecked="{Binding Settings.DryRun}" Margin="0,12,0,0"/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Test connection" Command="{Binding TestConnectionCommand}"/>
                        <Button Content="Save settings" Style="{StaticResource Primary}" Command="{Binding SaveSettingsCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="1" Content="Close" HorizontalAlignment="Right" Margin="0,10,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>

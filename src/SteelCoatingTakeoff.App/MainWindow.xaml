<Window x:Class="SteelCoatingTakeoff.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steel Coating Takeoff → Sage Estimating"
        Height="760" Width="1180"
        MinHeight="560" MinWidth="960"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource Accent}"
                    VerticalAlignment="Center">
                <TextBlock Text="SF" Foreground="White" FontWeight="Bold" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Steel Coating Takeoff" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Contour SF/LF per AISC Design Guide 19 · routes coating area to Sage assemblies"
                           Foreground="{StaticResource Muted}" FontSize="12"/>
            </StackPanel>
        </StackPanel>

        <!-- Totals -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL COATING AREA" Style="{StaticResource H2}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TotalArea, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                        <TextBlock Text="ft²" Margin="4,10,0,0" Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="INTUMESCENT AREA" Style="{StaticResource H2}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding IntumescentArea, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Accent2}"/>
                        <TextBlock Text="ft²" Margin="4,10,0,0" Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="STANDARD AREA" Style="{StaticResource H2}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StandardArea, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Good}"/>
                        <TextBlock Text="ft²" Margin="4,10,0,0" Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="LABOR" Style="{StaticResource H2}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TotalLabor, StringFormat={}{0:C0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Accent2}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="TAKEOFF" Style="{StaticResource H2}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding LineCount}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="lines ·" Margin="4,10,4,0" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="{Binding TotalLinearFeet, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="LF" Margin="4,10,0,0" Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Main -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Takeoff grid -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="STEEL TAKEOFF" Style="{StaticResource H2}"/>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="+ Add member" Style="{StaticResource Primary}" Command="{Binding AddRowCommand}"/>
                        <Button Content="Duplicate" Command="{Binding DuplicateRowCommand}"/>
                        <Button Content="Remove" Command="{Binding RemoveRowCommand}"/>
                        <Button Content="Clear all" Command="{Binding ClearCommand}"/>
                        <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"/>
                        <CheckBox Content="Show calculation"
                                  IsChecked="{Binding ShowCalculation}"
                                  VerticalAlignment="Center" Margin="12,0,0,0"
                                  ToolTip="Show how the selected line's area is derived, and how it reaches Sage."/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Rows}"
                              SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowHeight="38" Background="White" BorderThickness="0"
                              HorizontalGridLinesBrush="{StaticResource Line}"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              CanUserResizeRows="False">

                        <!-- "Show calculation" reveals the derivation under the selected row. -->
                        <DataGrid.Style>
                            <Style TargetType="DataGrid">
                                <Setter Property="RowDetailsVisibilityMode" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ShowCalculation,
                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="True">
                                        <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#F7F9FB" BorderBrush="{StaticResource Line}"
                                        BorderThickness="0,1,0,1" Padding="14,10">
                                    <StackPanel>
                                        <TextBlock Text="How this number is calculated"
                                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding CalculationSteps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                   Foreground="#5A6672" VerticalAlignment="Top"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Detail}"
                                                                   FontFamily="Consolas" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>

                        <DataGrid.Columns>

                            <DataGridTemplateColumn Header="Shape" Width="1.4*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding Families}"
                                                  DisplayMemberPath="Label"
                                                  SelectedItem="{Binding SelectedFamily, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="4,3" VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Size" Width="1.6*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding Sizes}"
                                                  DisplayMemberPath="Display"
                                                  SelectedItem="{Binding SelectedShape, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="True" IsTextSearchEnabled="True"
                                                  Margin="4,3" VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Plate W (in)" Width="0.8*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PlateWidthInches, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                 IsEnabled="{Binding IsPlate}"
                                                 TextAlignment="Right" Margin="4,3" VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Length (LF)" Width="0.8*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding LinearFeet, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                 TextAlignment="Right" Margin="4,3" VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Coats applies to every line (intumescent or not) and multiplies area. -->
                            <DataGridTemplateColumn Header="Coats" Width="0.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Coats, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0}}"
                                                 TextAlignment="Right" Margin="4,3" VerticalContentAlignment="Center"
                                                 ToolTip="Number of coats — multiplies the coating area (total SF), not the labor rate."/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- The DataGrid's cell-edit machinery defers a template checkbox's
                                 binding until the row loses focus (the box looks ticked while the
                                 row s
                                 till reads Standard), and neither IsReadOnly nor
                                 UpdateSourceTrigger fixes it without a worse side effect. So the
                                 binding stays plain for a correct initial state, and Click pushes
                                 the value into the row immediately (see IntumescentCheck_Click). -->
                            <DataGridTemplateColumn Header="Intumescent" Width="0.7*" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsIntumescent}"
                                                  Click="IntumescentCheck_Click"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- WFT / Coats / Rate only matter for intumescent, so these cells
                                 grey out and disable for standard lines. -->
                            <DataGridTemplateColumn Header="WFT (mils)" Width="0.7*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding WftMils, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                 IsEnabled="{Binding IsIntumescent}"
                                                 TextAlignment="Right" Margin="4,3" VerticalContentAlignment="Center"
                                                 ToolTip="Specified wet film thickness. Drives intumescent application labor: productivity = WFT ÷ divisor.">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsIntumescent}" Value="False">
                                                            <Setter Property="Background" Value="#F2F4F6"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="SF/LF" Width="0.6*"
                                                Binding="{Binding SfPerFoot, StringFormat={}{0:0.000}}"
                                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Area (ft²)" Width="0.7*"
                                                Binding="{Binding AreaSquareFeet, StringFormat={}{0:N0}}"
                                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Labor $" Width="0.8*"
                                                Binding="{Binding LaborAmount, StringFormat={}{0:C0}}"
                                                IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{StaticResource Accent2}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right column: Sage + activity -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="LABOR INPUTS" Style="{StaticResource H2}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Wage rate ($/hr)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding WageRate, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                         ToolTip="Hourly wage. Labor rate LR = wage ÷ productivity ($/SF)."/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Productivity (SF/hr)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Productivity, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                         ToolTip="Square feet applied per hour. Labor rate LR = wage ÷ productivity ($/SF)."/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="11"
                                   Text="Standard line: labor $/SF = LR.  Intumescent line: labor $/SF = (WFT ÷ divisor) × LR.  Coats (per line) multiply total SF."/>

                        <TextBlock Text="DEFAULTS" Style="{StaticResource H2}" Margin="0,14,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="WFT divisor" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.WftLaborDivisor, StringFormat={}{0:0.##}}"
                                         ToolTip="The 5 in WFT ÷ 5. Save settings to apply."/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Default WFT" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.DefaultWftMils, StringFormat={}{0:0.##}}"
                                         ToolTip="Pre-fills the WFT of each new intumescent line."/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Default coats" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Settings.DefaultCoats, StringFormat={}{0}}"
                                         ToolTip="Pre-fills the coats of each new line."/>
                            </StackPanel>
                        </Grid>

                        <WrapPanel Margin="0,14,0,0">
                            <Button Content="Connection settings…" Click="OpenConnectionSettings_Click"/>
                            <Button Content="Save settings" Command="{Binding SaveSettingsCommand}"/>
                        </WrapPanel>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="▶ Send ALL to Sage" Style="{StaticResource Primary}" Command="{Binding SendAllCommand}"/>
                            <Button Content="Send selected" Command="{Binding SendSelectedCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ACTIVITY" Style="{StaticResource H2}"/>
                        <ListBox ItemsSource="{Binding Activity}" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0,1"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

<Window x:Class="SteelCoatingTakeoff.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steel Coating Takeoff → Sage Estimating"
        Height="820" Width="1280"
        MinHeight="620" MinWidth="1040"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="212"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== Sidebar ===================== -->
        <Border Grid.Column="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14,18,14,14">

                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,0,0,22">
                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource Blue500}" VerticalAlignment="Center">
                        <TextBlock Text="SC" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Steel Coating" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Takeoff" FontSize="11.5" Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Footer -->
                <TextBlock DockPanel.Dock="Bottom" Margin="6,10,0,0" FontSize="11" Foreground="{StaticResource Muted}"
                           Text="v2.7 · Sage Estimating 25.2"/>

                <!-- Nav -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Style="{StaticResource NavButtonActive}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80A;" FontSize="15" Margin="0,0,11,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Takeoff" VerticalAlignment="Center"/>
                            <Border CornerRadius="9" Background="{StaticResource Blue100}" Padding="7,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding LineCount}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BlueInk}"/>
                            </Border>
                        </StackPanel>
                    </Button>
                    <!-- One entry: the connection window already covers databases,
                         assemblies and settings, so separate nav items were redundant. -->
                    <Button Style="{StaticResource NavButton}" Click="OpenConnectionSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="15" Margin="0,0,11,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Connection Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ===================== Main ===================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                <Grid Margin="24,14">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Takeoff" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Contour SF/LF per AISC Design Guide 19 · routes coating area to Sage assemblies"
                                   FontSize="12" Foreground="{StaticResource Muted}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding ExportCsvCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportPdfCommand}"
                                ToolTip="Clean PDF of every member, its quantities, labor and the totals.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE749;" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Export PDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource Primary}" Command="{Binding SendAllCommand}" Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE724;" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="Send all to Sage" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,24">
                <StackPanel>

                    <!-- Stat tiles -->
                    <UniformGrid Rows="1" Columns="5" Margin="0,0,0,8">
                        <Border Style="{StaticResource Card}" Margin="0,0,10,12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource Blue500}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Total coating area" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding TotalArea, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Blue600}"/>
                                    <TextBlock Text="ft²" Margin="5,9,0,0" FontSize="12" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource Amber}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Intumescent" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding IntumescentArea, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                    <TextBlock Text="ft²" Margin="5,9,0,0" FontSize="12" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource Green}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="Standard" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding StandardArea, StringFormat={}{0:N0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                                    <TextBlock Text="ft²" Margin="5,9,0,0" FontSize="12" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Labor" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/>
                                <TextBlock Text="{Binding TotalLabor, StringFormat={}{0:C0}}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Members" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/>
                                <TextBlock Text="{Binding LineCount}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,10,0,0"/>
                                <TextBlock FontSize="11" Foreground="{StaticResource Muted}" Margin="0,2,0,0">
                                    <Run Text="{Binding TotalLinearFeet, StringFormat={}{0:N0}, Mode=OneWay}"/><Run Text=" LF total"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Grid + right rail -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="352"/>
                        </Grid.ColumnDefinitions>

                        <!-- Takeoff grid card -->
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,20,0" Padding="16,14">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="Steel takeoff" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Command="{Binding AddRowCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Add member" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding DuplicateRowCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Duplicate" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding RemoveRowCommand}" ToolTip="Remove selected">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="13" Foreground="{StaticResource Red}"/>
                                        </Button>
                                        <Button Command="{Binding ClearCommand}" Content="Clear all"/>
                                        <CheckBox Content="Show calculation" IsChecked="{Binding ShowCalculation}"
                                                  VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"
                                                  ToolTip="Show how the selected line's area is derived, and how it reaches Sage."/>
                                    </StackPanel>
                                </Grid>

                                <DataGrid ItemsSource="{Binding Rows}"
                                          SelectedItem="{Binding SelectedRow}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          RowHeight="44" Background="Transparent" BorderThickness="0"
                                          HorizontalGridLinesBrush="{StaticResource Line}"
                                          SelectionMode="Single" SelectionUnit="FullRow"
                                          CanUserResizeRows="False" RowBackground="Transparent">

                                    <DataGrid.Style>
                                        <Style TargetType="DataGrid">
                                            <Setter Property="RowDetailsVisibilityMode" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.ShowCalculation, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Style>

                                    <DataGrid.RowDetailsTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Surface2}" BorderBrush="{StaticResource Line}"
                                                    BorderThickness="0,1,0,1" Padding="14,10">
                                                <StackPanel>
                                                    <TextBlock Text="How this number is calculated" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <ItemsControl ItemsSource="{Binding CalculationSteps}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="130"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{StaticResource Ink2}" VerticalAlignment="Top"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Detail}" FontFamily="Consolas" TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGrid.RowDetailsTemplate>

                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Shape" Width="1.3*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding Families}" DisplayMemberPath="Label"
                                                              SelectedItem="{Binding SelectedFamily, UpdateSourceTrigger=PropertyChanged}"
                                                              Margin="6,4" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Size" Width="1.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding Sizes}" DisplayMemberPath="Display"
                                                              SelectedItem="{Binding SelectedShape, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEditable="True" IsTextSearchEnabled="True"
                                                              Margin="6,4" VerticalContentAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Plate W" Width="0.7*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding PlateWidthInches, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                             IsEnabled="{Binding IsPlate}" TextAlignment="Right" Margin="6,4"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Length" Width="0.8*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding LinearFeet, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                             TextAlignment="Right" Margin="6,4"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Coats" Width="0.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Coats, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0}}"
                                                             TextAlignment="Right" Margin="6,4"
                                                             ToolTip="Number of coats — multiplies the coating area (total SF), not the labor rate."/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Coating: toggle + badge. IsReadOnly keeps the cell out of edit
                                             mode so the toggle commits on the click (see IntumescentCheck_Click). -->
                                        <DataGridTemplateColumn Header="Coating" Width="1.35*" IsReadOnly="True">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                                        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding IsIntumescent}"
                                                                  Click="IntumescentCheck_Click" VerticalAlignment="Center"/>
                                                        <Border x:Name="badgeBd" CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                                                VerticalAlignment="Center" Background="{StaticResource GreenSoft}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="badgeDot" Width="6" Height="6" Fill="{StaticResource Green}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                                <TextBlock x:Name="badgeTxt" Text="Standard" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource GreenInk}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsIntumescent}" Value="True">
                                                            <Setter TargetName="badgeBd" Property="Background" Value="{StaticResource AmberSoft}"/>
                                                            <Setter TargetName="badgeDot" Property="Fill" Value="{StaticResource Amber}"/>
                                                            <Setter TargetName="badgeTxt" Property="Text" Value="Intumescent"/>
                                                            <Setter TargetName="badgeTxt" Property="Foreground" Value="{StaticResource AmberInk}"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="WFT" Width="0.7*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding WftMils, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                             IsEnabled="{Binding IsIntumescent}" TextAlignment="Right" Margin="6,4"
                                                             ToolTip="Specified wet film thickness. Drives intumescent application labor: productivity = WFT ÷ divisor."/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="SF/LF" Width="0.6*"
                                                            Binding="{Binding SfPerFoot, StringFormat={}{0:0.000}}" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="8,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Area (ft²)" Width="0.75*"
                                                            Binding="{Binding AreaSquareFeet, StringFormat={}{0:N0}}" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="8,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Blue600}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="Labor" Width="0.75*"
                                                            Binding="{Binding LaborAmount, StringFormat={}{0:C0}}" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="8,0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Right rail -->
                        <StackPanel Grid.Column="1">

                            <!-- Labor & Sage -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="Labor &amp; Sage" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Dry run" FontSize="12" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding Settings.DryRun}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Wage rate ($/hr)" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding WageRate, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                     TextAlignment="Right" ToolTip="Hourly wage. Labor $/SF = wage ÷ effective productivity."/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Productivity (SF/hr)" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding Productivity, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.##}}"
                                                     TextAlignment="Right" ToolTip="Square feet applied per hour. On intumescent lines WFT divides this: 100 SF/hr at 20 mils ÷ 5 becomes 25 SF/hr."/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Text="Labor prod factor (L.Prod Factor)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Text="{Binding LaborProductivityFactor, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.####}}"
                                                 TextAlignment="Right"
                                                 ToolTip="Sent to Sage's L.Prod Factor column on each labor line. It does not change the $/SF calculated here. Sage only keeps this value on items that have a crew — the current coating items do not, so it resets to 1 and the activity log reports it."/>
                                    </StackPanel>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="WFT ÷" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding Settings.WftLaborDivisor, StringFormat={}{0:0.##}}" TextAlignment="Right"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Def. WFT" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding Settings.DefaultWftMils, StringFormat={}{0:0.##}}" TextAlignment="Right"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Def. coats" Style="{StaticResource FieldLabel}"/>
                                            <TextBox Text="{Binding Settings.DefaultCoats, StringFormat={}{0}}" TextAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource Muted}" LineHeight="18"
                                               Text="$/SF = wage ÷ effective productivity.  On intumescent, WFT divides productivity: at 20 mils ÷ 5, 100 SF/hr becomes 25 SF/hr.  Coats multiply total SF, never the rate."/>

                                    <Border Height="1" Background="{StaticResource Line}" Margin="-18,16,-18,0"/>

                                    <Button Style="{StaticResource Primary}" Command="{Binding SendAllCommand}" Margin="0,16,0,0"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE724;" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center" Foreground="White"/>
                                            <TextBlock Text="Send all to Sage" VerticalAlignment="Center" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Send selected" Command="{Binding SendSelectedCommand}" Margin="0" HorizontalAlignment="Stretch"/>
                                        <Button Grid.Column="2" Click="OpenConnectionSettings_Click" Margin="0" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <Button Content="Save settings" Command="{Binding SaveSettingsCommand}" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>

                            <!-- Activity -->
                            <Border Style="{StaticResource Card}" Margin="0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Activity" Style="{StaticResource CardTitle}" Margin="0,0,0,10"/>
                                    <ListBox ItemsSource="{Binding Activity}" BorderThickness="0" Background="Transparent"
                                             FontFamily="Consolas" FontSize="11.5" MaxHeight="300"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0,2"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource Ink2}"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
